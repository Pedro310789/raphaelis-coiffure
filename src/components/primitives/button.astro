---
// Exports both the component AND `buttonVariants` so anchor tags can be styled as buttons.
import type { HTMLAttributes } from "astro/types";
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";

export const buttonVariants = cva(
  [
    "inline-flex items-center justify-center gap-2 whitespace-nowrap",
    "text-xs/[1.2] md:text-sm/[1.2] font-normal tracking-[0.03em] uppercase",
    "transition-colors disabled:pointer-events-none disabled:opacity-50",
    '[&_svg]:pointer-events-none [&_svg:not([class*="size-"])]:size-4 [&_svg]:shrink-0',
  ],
  {
    variants: {
      variant: {
        main: [
          "border border-primary text-foreground",
          "hover:bg-background hover:border-border",
        ],
        "main-light": [
          "border border-border text-white",
          "hover:bg-white/10 hover:border-primary-foreground/60",
        ],
        tertiary: [
          "rounded-sm text-primary",
          "hover:text-muted-foreground",
        ],
        "tertiary-light": [
          "rounded-sm text-primary-foreground",
          "hover:text-primary-foreground/60",
        ],
      },
      size: {
        default: "h-10 md:h-12 px-8",
      },
    },
    defaultVariants: {
      variant: "main",
      size: "default",
    },
  },
);

export type ButtonVariantProps = VariantProps<typeof buttonVariants>;

export interface Props
  extends Omit<HTMLAttributes<"button">, "class">, ButtonVariantProps {
  class?: string;
}

const {
  variant,
  size,
  class: className,
  type = "button",
  ...rest
} = Astro.props;
---

<button
  class={cn(buttonVariants({ variant, size }), className)}
  type={type}
  {...rest}
>
  <slot />
</button>
