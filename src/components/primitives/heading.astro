---
/**
 * Heading — decouples semantic level (h1…h6) from visual size.
 *
 * Most projects need to render an h1 that LOOKS like a small heading,
 * or an h3 that looks like a hero title. This primitive lets you set
 * the HTML tag and the visual variant independently — essential for
 * accessibility and SEO.
 *
 *   <Heading as="h1" size="3xl">Hero title</Heading>
 *   <Heading as="h2" size="md">Small section heading</Heading>
 */
import type { HTMLAttributes } from "astro/types";
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";

export const headingVariants = cva(
  "font-semibold font-serif tracking-tight text-foreground",
  {
    variants: {
      size: {
        sm: "text-lg",
        md: "text-xl",
        lg: "text-2xl",
        xl: "text-3xl",
        "2xl": "text-4xl",
        "3xl": "text-5xl md:text-6xl",
        "4xl": "text-6xl md:text-7xl",
      },
      balance: {
        true: "text-balance",
        false: "",
      },
    },
    defaultVariants: {
      size: "xl",
      balance: true,
    },
  },
);

export type HeadingVariantProps = VariantProps<typeof headingVariants>;

export interface Props
  extends Omit<HTMLAttributes<"h1">, "class">, HeadingVariantProps {
  class?: string;
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
}

const {
  size,
  balance,
  class: className,
  as: Tag = "h2",
  ...rest
} = Astro.props;
---

<Tag class={cn(headingVariants({ size, balance }), className)} {...rest}>
  <slot />
</Tag>
