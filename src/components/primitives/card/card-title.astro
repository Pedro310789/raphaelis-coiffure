---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@/lib/utils";

export interface Props extends Omit<HTMLAttributes<"div">, "class"> {
  class?: string;
  /** HTML tag to render. Default is div so Card composes into any heading level. */
  as?: "h2" | "h3" | "h4" | "div";
}

const { class: className, as: Tag = "div", ...rest } = Astro.props;
---

<Tag class={cn("leading-none font-semibold font-serif", className)} {...rest}>
  <slot />
</Tag>
