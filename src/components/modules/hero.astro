---
import { cva, type VariantProps } from 'class-variance-authority';
import Container from '@/components/primitives/container.astro';
import Heading from '@/components/primitives/heading.astro';
import Badge from '@/components/primitives/badge.astro';
import { buttonVariants } from '@/components/primitives/button.astro';
import type { CTALink, ImageProps } from '@/types/modules';
import { cn } from '@/lib/utils';

const wrapperVariants = cva('py-16 md:py-24', {
  variants: {
    align: {
      center: 'text-center',
      left: 'text-left',
    },
  },
  defaultVariants: {
    align: 'center',
  },
});

export interface Props extends VariantProps<typeof wrapperVariants> {
  eyebrow?: string;
  title: string;
  description?: string;
  primaryCta?: CTALink;
  secondaryCta?: CTALink;
  image?: ImageProps;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryCta,
  secondaryCta,
  image,
  align = 'center',
  class: className,
} = Astro.props;

const contentAlignment =
  align === 'center' ? 'mx-auto max-w-3xl items-center' : 'max-w-3xl items-start';
const ctaAlignment = align === 'center' ? 'justify-center' : 'justify-start';
---

<section class={cn(wrapperVariants({ align }), className)}>
  <Container>
    <div class={cn('flex flex-col gap-6', contentAlignment)}>
      {eyebrow && <Badge variant="secondary">{eyebrow}</Badge>}

      <Heading as="h1" size="h1">{title}</Heading>

      {
        description && (
          <p class="text-lg md:text-xl text-muted-foreground text-balance max-w-2xl">
            {description}
          </p>
        )
      }

      {
        (primaryCta || secondaryCta) && (
          <div class={cn('flex flex-wrap gap-3 mt-2', ctaAlignment)}>
            {primaryCta && (
              <a
                href={primaryCta.href}
                class={buttonVariants({ variant: primaryCta.variant ?? 'default', size: 'lg' })}
                target={primaryCta.external ? '_blank' : undefined}
                rel={primaryCta.external ? 'noopener noreferrer' : undefined}
              >
                {primaryCta.label}
              </a>
            )}
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                class={buttonVariants({ variant: secondaryCta.variant ?? 'outline', size: 'lg' })}
                target={secondaryCta.external ? '_blank' : undefined}
                rel={secondaryCta.external ? 'noopener noreferrer' : undefined}
              >
                {secondaryCta.label}
              </a>
            )}
          </div>
        )
      }
    </div>

    {
      image && (
        <div class="mt-12 md:mt-16">
          <img
            src={image.src}
            alt={image.alt}
            width={image.width}
            height={image.height}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="w-full rounded-lg border shadow-sm"
          />
        </div>
      )
    }
  </Container>
</section>
