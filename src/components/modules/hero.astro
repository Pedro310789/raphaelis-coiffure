---
import type { CTALink } from "@/types/modules";
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import Navbar from "@/components/modules/navbar.astro";
import heroImage from "@/assets/images/hero.png";
import settings from "@/data/settings.json";
import { cn, isExternalUrl } from "@/lib/utils";

export interface Props {
  heading: string;
  subtitle: string;
  cta: CTALink;
  discover: { label: string; slogan: string; address: string };
}

const { heading, subtitle, cta, discover } = Astro.props;

const bookingUrl = settings.bookingUrl;
const bookingExternal = isExternalUrl(bookingUrl);
---

<section class="relative flex flex-col overflow-hidden">
  {/* Background: full-bleed photo + gradient vignette */}
  <div aria-hidden class="pointer-events-none absolute inset-0">
    <Image
      src={heroImage}
      alt=""
      loading="eager"
      fetchpriority="high"
      class="reveal-on-scroll animate-scale-in absolute inset-0 size-full object-cover object-[75%_50%] md:object-center"
    />
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.3) 100%), linear-gradient(0deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.3) 100%), linear-gradient(90deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.2) 100%)"
    >
    </div>
  </div>

  <Navbar />

  {/* Hero content — vertically centered in remaining space */}
  <div
    class="relative z-10 flex flex-1 flex-col items-center justify-between gap-32 px-5 pt-37 md:pt-31 pb-4 md:pb-6"
  >
    <div class="flex w-full max-w-117 flex-col items-center gap-10">
      {/* Title group: H1 + divider + subtitle */}
      <div class="flex w-full flex-col items-center gap-8">
        <Heading
          as="h1"
          size="h1"
          balance={false}
          animation="fade-up"
          class="w-full text-center text-[48px]/none text-white md:text-[88px]/none"
        >
          {heading}
        </Heading>
        <hr class="w-32 border-background" />
        <p
          class="reveal-on-scroll animate-fade-up text-center text-xs/[1.3] font-normal uppercase tracking-wider text-background"
          style="--reveal-delay: 120ms"
        >
          {subtitle}
        </p>
      </div>

      {/* CTA button */}
      <a
        href={bookingUrl}
        target={bookingExternal ? "_blank" : undefined}
        rel={bookingExternal ? "noopener noreferrer" : undefined}
        class={cn(
          buttonVariants({ variant: "main-light" }),
          "reveal-on-scroll animate-fade-up",
        )}
        style="--reveal-delay: 240ms"
      >
        {cta.label}
      </a>
    </div>
    {/* Discover section — bottom of viewport */}
    <div class="relative z-10 pb-16 md:pb-0 w-full">
      {/* Discover label + vertical line, centered */}
      <div class="flex flex-col items-center gap-3 pb-6 md:pb-2">
        <span
          class="text-xs/[1.3] font-normal uppercase tracking-wider text-background"
        >
          {discover.label}
        </span>
        <div
          class="h-10 w-px bg-background md:bg-primary-foreground/60"
          aria-hidden="true"
        >
        </div>
      </div>

      {/* Slogan (left) + address (right); stacks on mobile */}
      <Container
        size="page"
        class="flex flex-col items-center gap-2 md:flex-row md:justify-between md:gap-0"
      >
        <span
          class="text-xs/[1.3] font-normal uppercase tracking-wider text-background"
        >
          {discover.slogan}
        </span>
        <span
          class="text-xs/[1.3] font-normal uppercase tracking-wider text-background"
        >
          {discover.address}
        </span>
      </Container>
    </div>
  </div>
</section>
