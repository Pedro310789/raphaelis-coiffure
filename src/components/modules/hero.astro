---
import type { CTALink } from "@/types/modules";
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/translations";
import heroImage from "@/assets/hero.png";

export interface Props {
  heading: string;
  subtitle: string;
  cta: CTALink;
  discover: { label: string; slogan: string; address: string };
}

const { heading, subtitle, cta, discover } = Astro.props;

const locale = (Astro.currentLocale ?? 'fr') as Lang;
const t = useTranslations(locale);

const navLinks = [
  { label: t('nav.home'), href: getRelativeLocaleUrl(locale, '/') },
  { label: t('nav.maison'), href: getRelativeLocaleUrl(locale, '/maison') },
  { label: t('nav.services'), href: getRelativeLocaleUrl(locale, '/services') },
  { label: t('nav.collection'), href: getRelativeLocaleUrl(locale, '/collection') },
  { label: t('nav.contact'), href: getRelativeLocaleUrl(locale, '/contact') },
];

const currentPath = Astro.url.pathname.replace(/^\/en/, '') || '/';
const frHref = getRelativeLocaleUrl('fr', currentPath);
const enHref = getRelativeLocaleUrl('en', currentPath);
---

<section class="relative flex min-h-screen flex-col overflow-hidden">
  {/* Background: full-bleed photo + gradient vignette */}
  <div aria-hidden class="pointer-events-none absolute inset-0">
    <Image
      src={heroImage}
      alt=""
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 size-full object-cover"
    />
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.3) 100%), linear-gradient(0deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.3) 100%), linear-gradient(90deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.2) 100%)"
    >
    </div>
  </div>

  {/* Mobile menu overlay */}
  <div
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label={t('nav.label')}
    class="fixed inset-0 z-50 hidden flex-col bg-[#181818] md:hidden"
  >
    {/* Top bar: close button */}
    <div class="flex h-24 items-center justify-end px-4">
      <button
        id="menu-close"
        aria-label={t('nav.closeMenu')}
        class="flex items-center justify-center p-2 text-white/80 transition-colors hover:text-white"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="4" y1="4" x2="20" y2="20" />
          <line x1="20" y1="4" x2="4" y2="20" />
        </svg>
      </button>
    </div>

    {/* Nav links — centered */}
    <nav aria-label={t('nav.label')} class="flex flex-1 flex-col items-center justify-center gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-display text-[28px]/none text-white/80 transition-colors hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </nav>

    {/* Language selector */}
    <div class="flex items-center justify-center gap-4 pb-12" aria-label={t('lang.selector')}>
      {locale === 'fr' ? (
        <span
          lang="fr"
          aria-current="true"
          class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-white cursor-default"
        >
          FR
        </span>
      ) : (
        <a
          href={frHref}
          lang="fr"
          class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-white/50 transition-colors hover:text-white"
        >
          FR
        </a>
      )}
      <div class="h-3 w-px bg-white/30" aria-hidden="true"></div>
      {locale === 'en' ? (
        <span
          lang="en"
          aria-current="true"
          class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-white cursor-default"
        >
          EN
        </span>
      ) : (
        <a
          href={enHref}
          lang="en"
          class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-white/50 transition-colors hover:text-white"
        >
          EN
        </a>
      )}
    </div>
  </div>

  {/* Navbar */}
  <header class="relative z-10 h-24">
    <Container
      size="page"
      class="flex h-full items-center justify-end md:justify-between"
    >
      {/* Nav links — hidden on mobile, shown md+ */}
      <nav aria-label={t('nav.label')} class="hidden md:block">
        <ul class="flex items-center gap-10">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-white transition-colors hover:text-primary-foreground/60"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {/* Right side: language selector + hamburger */}
      <div class="flex items-center gap-5">
        {/* Language selector */}
        <div class="flex items-center gap-3" aria-label={t('lang.selector')}>
          {locale === 'fr' ? (
            <span
              lang="fr"
              aria-current="true"
              class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-white cursor-default"
            >
              FR
            </span>
          ) : (
            <a
              href={frHref}
              lang="fr"
              class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-primary-foreground/60 transition-colors hover:text-white"
            >
              FR
            </a>
          )}
          <div class="h-3 w-px bg-primary-foreground/40" aria-hidden="true"></div>
          {locale === 'en' ? (
            <span
              lang="en"
              aria-current="true"
              class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-white cursor-default"
            >
              EN
            </span>
          ) : (
            <a
              href={enHref}
              lang="en"
              class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-primary-foreground/60 transition-colors hover:text-white"
            >
              EN
            </a>
          )}
        </div>

        {/* Hamburger — mobile only */}
        <button
          id="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label={t('nav.openMenu')}
          class="flex flex-col items-center justify-center gap-[5px] p-2 text-white md:hidden"
        >
          <span class="block h-px w-5 bg-white"></span>
          <span class="block h-px w-5 bg-white"></span>
          <span class="block h-px w-5 bg-white"></span>
        </button>
      </div>
    </Container>
  </header>

  {/* Hero content — vertically centered in remaining space */}
  <div
    class="relative z-10 flex flex-1 flex-col items-center justify-center px-4 py-10 md:py-0"
  >
    <div
      class="flex w-full max-w-[467px] flex-col items-center gap-8 md:gap-10"
    >
      {/* Title group: H1 + divider + subtitle */}
      <div class="flex w-full flex-col items-center gap-6 md:gap-8">
        <Heading
          as="h1"
          size="h1"
          balance={false}
          class="w-full text-center text-[48px]/none text-white md:text-[88px]/none"
        >
          {heading}
        </Heading>
        <hr class="w-32 border-background" />
        <p
          class="text-center text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-primary-foreground/60"
        >
          {subtitle}
        </p>
      </div>

      {/* CTA button */}
      <a href={cta.href} class={buttonVariants({ variant: "main-light" })}>
        {cta.label}
      </a>
    </div>
  </div>

  {/* Discover section — bottom of viewport */}
  <div class="relative z-10 pb-6">
    {/* Discover label + vertical line, centered */}
    <div class="flex flex-col items-center gap-3 pb-4 md:pb-2">
      <span
        class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-primary-foreground/60"
      >
        {discover.label}
      </span>
      <div class="h-10 w-px bg-primary-foreground/60" aria-hidden="true"></div>
    </div>

    {/* Slogan (left) + address (right); stacks on mobile */}
    <Container
      size="page"
      class="flex flex-col items-center gap-2 md:flex-row md:justify-between md:gap-0"
    >
      <span
        class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-primary-foreground/60"
      >
        {discover.slogan}
      </span>
      <span
        class="text-xs/[1.3] font-normal uppercase tracking-[0.05em] text-primary-foreground/60"
      >
        {discover.address}
      </span>
    </Container>
  </div>
</section>

<script>
  const toggle = document.getElementById('menu-toggle');
  const closeBtn = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('flex');
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
