---
/**
 * MaisonAbout — "À propos / Un intérieur pensé comme une pause" (Figma 3430:3012).
 *
 * Maison-page atmosphere block: interior photo on the left, an overline +
 * divider + H3 + body + tertiary CTA on the right. Same two-column rhythm as
 * the home Founders section, but H3-sized, single image (no caption) and a
 * single body paragraph. Mobile-first: the columns stack and the photo goes
 * full-width below the lg breakpoint.
 */
import type { CTALink } from "@/types/modules";
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import { cn } from "@/lib/utils";
import aboutImage from "@/assets/images/atmosphere_about.jpg";

export interface Props {
  overline: string;
  heading: string;
  body: string[];
  imageAlt: string;
  cta: CTALink;
}

const { overline, heading, body, imageAlt, cta } = Astro.props;
---

<section class="bg-muted">
  <Container size="page" as="div" class="py-16 md:py-20 xl:py-24">
    <div
      class="flex flex-col gap-10 md:flex-row md:items-center md:gap-16 xl:gap-33.5"
    >
      {/* Left: interior photo */}
      <div
        class="relative w-full shrink-0 overflow-hidden aspect-526/560 md:w-2/5 xl:w-131.5"
      >
        <Image
          src={aboutImage}
          alt={imageAlt}
          widths={[526, 800, 1052]}
          sizes="(min-width: 1280px) 526px, (min-width: 768px) 40vw, 100vw"
          class="absolute inset-0 size-full object-cover"
          loading="lazy"
        />
      </div>

      {/* Right: text content */}
      <div class="flex flex-1 flex-col gap-10 xl:gap-14">
        {/* Heading block + body */}
        <div class="flex flex-col gap-6 md:gap-8">
          {/* Overline + divider + H3 */}
          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-4">
              <p
                class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
              >
                {overline}
              </p>
              <div class="h-px w-12 bg-muted-foreground" aria-hidden="true">
              </div>
            </div>
            <Heading
              as="h2"
              size="h3"
              balance={false}
              class="text-[32px]/none md:text-[40px]/none xl:text-[46px]/none"
            >
              {heading}
            </Heading>
          </div>

          {/* Body paragraphs */}
          <div class="flex flex-col gap-6">
            {
              body.map((paragraph) => (
                <p class="text-base/normal text-body-foreground">{paragraph}</p>
              ))
            }
          </div>
        </div>

        {/* CTA */}
        <a
          href={cta.href}
          class={cn(buttonVariants({ variant: "tertiary" }), "self-start px-0")}
        >
          {cta.label}
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</section>
