---
/**
 * MaisonVision — "Notre vision" statement for the maison page (Figma 3430:3281).
 *
 * Two flanking photos around a centered editorial column: faint brand monogram
 * watermark, overline + divider, H3 statement, and a short body paragraph.
 * Mobile-first: a single stacked column (photo → text → photo) that becomes a
 * three-up grid at lg, where the photos crop to tall 620px portraits and the
 * text vertically centres between them. Sits on Primary/100 (#F7F6F3 = bg-muted).
 */
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";

export interface Props {
  overline: string;
  heading: string;
  body: string[];
  monogram: ImageMetadata;
  leftImage: ImageMetadata;
  leftImageAlt: string;
  rightImage: ImageMetadata;
  rightImageAlt: string;
}

const {
  overline,
  heading,
  body,
  monogram,
  leftImage,
  leftImageAlt,
  rightImage,
  rightImageAlt,
} = Astro.props;

const imageSizes = "(min-width: 1024px) 33vw, 100vw";
const imageWidths = [430, 660, 900];
---

<section class="bg-muted">
  <Container size="page" as="div" class="py-12 md:py-20 xl:py-24">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-3 lg:gap-15">
      {/* Left photo */}
      <div
        class="reveal-on-scroll animate-scale-in group relative w-full overflow-hidden aspect-3/4 lg:aspect-auto lg:h-155"
      >
        <Image
          src={leftImage}
          alt={leftImageAlt}
          widths={imageWidths}
          sizes={imageSizes}
          class="absolute inset-0 size-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
          loading="lazy"
        />
      </div>

      {/* Center editorial column */}
      <div class="flex flex-col items-center gap-10 text-center lg:gap-12">
        {/* Brand monogram watermark — decorative */}
        <Image
          src={monogram}
          alt=""
          aria-hidden="true"
          widths={[66, 132]}
          sizes="66px"
          class="h-auto w-16 opacity-25"
          loading="lazy"
        />

        <div class="flex flex-col items-center gap-8">
          {/* Heading block */}
          <div class="flex flex-col items-center gap-6">
            <div class="flex flex-col items-center gap-4">
              <p
                class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
              >
                {overline}
              </p>
              <div class="h-px w-12 bg-muted-foreground" aria-hidden="true">
              </div>
            </div>
            <Heading
              as="h2"
              size="h3"
              animation="fade-up"
              class="text-center text-[32px]/none md:text-[40px]/none lg:text-[46px]/none"
            >
              <span set:html={heading} />
            </Heading>
          </div>

          {/* Body */}
          <div
            class="reveal-on-scroll animate-fade-up flex flex-col gap-4"
            style="--reveal-delay: 120ms"
          >
            {
              body.map((paragraph) => (
                <p class=" max-w-prose text-sm/normal tracking-[0.01em] text-body-foreground">
                  {paragraph}
                </p>
              ))
            }
          </div>
        </div>
      </div>

      {/* Right photo */}
      <div
        class="reveal-on-scroll animate-scale-in group relative w-full overflow-hidden aspect-3/4 lg:aspect-auto lg:h-155"
      >
        <Image
          src={rightImage}
          alt={rightImageAlt}
          widths={imageWidths}
          sizes={imageSizes}
          class="absolute inset-0 size-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
          loading="lazy"
        />
      </div>
    </div>
  </Container>
</section>
