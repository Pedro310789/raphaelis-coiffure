---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import type { CTALink } from "@/types/modules";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import settings from "@/data/settings.json";
import { cn, isExternalUrl } from "@/lib/utils";
import rightIcon from "@/assets/icons/right-icon.svg?raw";

const serviceImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/services/*",
  { eager: true },
);

// Single global booking link (editable in Pages CMS → Site settings) shared by
// every card CTA, so a booking-tool change only needs one edit.
const bookingUrl = settings.bookingUrl;
const bookingExternal = isExternalUrl(bookingUrl);

interface ServiceCard {
  numeral: string;
  image: { src: string; alt: string };
  title: string;
  body: string;
  cta: Pick<CTALink, "label">;
}

export interface Props {
  overline: string;
  heading: string[];
  cards: ServiceCard[];
}

const { overline, heading, cards } = Astro.props;
---

<section class="bg-background">
  <Container size="page" as="div" class="py-10 md:py-20 xl:py-24">
    <div class="flex flex-col items-center gap-12 xl:gap-24">
      {/* Heading block */}
      <div class="flex flex-col items-center gap-6 text-center">
        <div class="flex flex-col items-center gap-4">
          <p
            class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
          >
            {overline}
          </p>
          <div class="h-px w-12 bg-muted-foreground" aria-hidden="true"></div>
        </div>
        <Heading
          as="h2"
          size="h2"
          balance={false}
          animation="fade-up"
          class="text-center text-[36px]/none md:text-[46px]/none xl:text-[56px]/none"
        >
          {heading.map((line) => <span class="block">{line}</span>)}
        </Heading>
      </div>

      {/* Cards grid */}
      <div
        class="animate-stagger grid w-full grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6"
      >
        {
          cards.map((card) => {
            const imgKey = `/${card.image.src}`;
            const imgData = serviceImages[imgKey]?.default;
            return (
              <div class="reveal-on-scroll animate-fade-up flex flex-col gap-4 md:gap-8">
                {/* Image */}
                <div class="group relative aspect-4/5 w-full overflow-hidden">
                  {imgData ? (
                    <Image
                      src={imgData}
                      alt={card.image.alt}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                      widths={[400, 600, 816]}
                      sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
                      loading="lazy"
                    />
                  ) : (
                    <img
                      src={card.image.src}
                      alt={card.image.alt}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                  )}
                </div>

                {/* Below image: numeral row + content — flex-1 chain keeps CTA at bottom */}
                <div class="flex flex-1 flex-col gap-4 md:gap-6">
                  {/* Numeral + extending divider */}
                  <div class="flex items-center gap-6">
                    <span
                      class="w-5 shrink-0 font-display text-xl/[1.3] italic text-muted-foreground"
                      aria-hidden="true"
                    >
                      {card.numeral}
                    </span>
                    <div
                      class="h-px flex-1 bg-muted-foreground"
                      aria-hidden="true"
                    />
                  </div>

                  {/* Title, body, CTA */}
                  <div class="flex flex-1 flex-col items-start gap-4">
                    <div class="flex flex-1 flex-col gap-4">
                      <Heading as="h3" size="h4">
                        {card.title}
                      </Heading>
                      <p class="text-sm/normal tracking-[0.01em] text-body-foreground">
                        {card.body}
                      </p>
                    </div>
                    <a
                      href={bookingUrl}
                      target={bookingExternal ? "_blank" : undefined}
                      rel={bookingExternal ? "noopener noreferrer" : undefined}
                      class={cn(
                        buttonVariants({ variant: "tertiary" }),
                        "px-0",
                      )}
                    >
                      {card.cta.label}
                      <Fragment set:html={rightIcon} />
                    </a>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </Container>
</section>
