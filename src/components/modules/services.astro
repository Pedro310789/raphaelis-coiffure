---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import type { CTALink } from "@/types/modules";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import { cn } from "@/lib/utils";

const serviceImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/services/*',
  { eager: true },
);

interface ServiceCard {
  numeral: string;
  image: { src: string; alt: string };
  title: string;
  body: string;
  cta: CTALink;
}

export interface Props {
  overline: string;
  heading: string[];
  cards: ServiceCard[];
}

const { overline, heading, cards } = Astro.props;
---

<section class="bg-background">
  <Container size="page" as="div" class="py-16 md:py-20 xl:py-24">
    <div class="flex flex-col items-center gap-12 xl:gap-24">

      {/* Heading block */}
      <div class="flex flex-col items-center gap-6 text-center">
        <div class="flex flex-col items-center gap-4">
          <p class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground">
            {overline}
          </p>
          <div class="h-px w-12 bg-muted-foreground" aria-hidden="true"></div>
        </div>
        <Heading
          as="h2"
          size="h2"
          balance={false}
          class="text-center text-[36px]/none md:text-[46px]/none xl:text-[56px]/none"
        >
          {heading.map((line) => <span class="block">{line}</span>)}
        </Heading>
      </div>

      {/* Cards grid */}
      <div class="grid w-full grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
        {
          cards.map((card) => {
            const imgKey = `/${card.image.src}`;
            const imgData = serviceImages[imgKey]?.default;
            return (
              <div class="flex flex-col gap-8">

                {/* Image */}
                <div class="relative aspect-[4/5] w-full overflow-hidden">
                  {imgData ? (
                    <Image
                      src={imgData}
                      alt={card.image.alt}
                      class="absolute inset-0 h-full w-full object-cover"
                      widths={[400, 600, 816]}
                      sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
                      loading="lazy"
                    />
                  ) : (
                    <img
                      src={card.image.src}
                      alt={card.image.alt}
                      class="absolute inset-0 h-full w-full object-cover"
                      loading="lazy"
                    />
                  )}
                </div>

                {/* Below image: numeral row + content — flex-1 chain keeps CTA at bottom */}
                <div class="flex flex-1 flex-col gap-6">

                  {/* Numeral + extending divider */}
                  <div class="flex items-center gap-6">
                    <span
                      class="w-5 shrink-0 font-display text-xl/[1.3] italic text-muted-foreground"
                      aria-hidden="true"
                    >
                      {card.numeral}
                    </span>
                    <div class="h-px flex-1 bg-muted-foreground" aria-hidden="true" />
                  </div>

                  {/* Title, body, CTA */}
                  <div class="flex flex-1 flex-col items-start gap-4">
                    <div class="flex flex-1 flex-col gap-4">
                      <Heading as="h3" size="h4">
                        {card.title}
                      </Heading>
                      <p class="text-sm/[1.5] tracking-[0.01em] text-body-foreground">
                        {card.body}
                      </p>
                    </div>
                    <a
                      href={card.cta.href}
                      class={cn(buttonVariants({ variant: "tertiary" }), "px-0")}
                    >
                      {card.cta.label}
                      <svg
                        width="16"
                        height="16"
                        viewBox="0 0 16 16"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path
                          d="M3 8h10M9 4l4 4-4 4"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </a>
                  </div>

                </div>
              </div>
            );
          })
        }
      </div>

    </div>
  </Container>
</section>
