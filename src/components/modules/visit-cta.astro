---
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/primitives/button.astro";
import Heading from "@/components/primitives/heading.astro";
import { cn } from "@/lib/utils";
import ctaImage from "@/assets/images/cta.png";

export interface Props {
  overline: string;
  heading: { line1: string; line2: string };
  body: string;
  address: { label: string; line1: string; line2: string };
  contact: { label: string; email: string; phone: string };
  hours: {
    label: string;
    rows: { day: string; time: string; muted?: boolean }[];
  };
  cta: { label: string; href: string };
}

const { overline, heading, body, address, contact, hours, cta } = Astro.props;
---

<section class="flex flex-col lg:flex-row">
  {/* Left: image */}
  <div
    class="relative w-full overflow-hidden aspect-4/3 md:aspect-video lg:aspect-auto lg:flex-1 lg:basis-1/2"
  >
    <Image
      src={ctaImage}
      alt=""
      widths={[600, 900, 1200]}
      sizes="(min-width: 1024px) 50vw, 100vw"
      class="absolute inset-0 size-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/20" aria-hidden="true"></div>
  </div>

  {/* Right: dark content panel */}
  <div
    class="flex flex-col justify-center gap-10 bg-primary px-4 py-12 sm:px-8 md:px-12 md:py-16 lg:flex-1 lg:basis-1/2 lg:gap-12 lg:py-24 lg:pl-20 lg:pr-18"
  >
    {/* Info section */}
    <div class="flex flex-col gap-8 lg:gap-10">
      {/* Info content: heading block + address/contact */}
      <div class="flex flex-col gap-10 lg:gap-16">
        {/* Overline + heading + body */}
        <div class="flex flex-col gap-6 lg:gap-8">
          <div class="flex flex-col gap-4">
            <p
              class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
            >
              {overline}
            </p>
            <div class="h-px w-12 bg-muted-foreground" aria-hidden="true"></div>
          </div>
          <div class="flex flex-col gap-6">
            <Heading
              as="h2"
              size="h3"
              balance={false}
              class="text-primary-foreground text-[30px]/none md:text-[38px]/none lg:text-[46px]/none"
            >
              <span class="block">{heading.line1}</span>
              <span class="block text-primary-foreground/70"
                >{heading.line2}</span
              >
            </Heading>
            <p
              class="text-sm/normal tracking-[0.01em] text-primary-foreground/60"
            >
              {body}
            </p>
          </div>
        </div>

        {/* Address + Contact */}
        <div class="flex flex-col gap-6 sm:flex-row sm:gap-2">
          <div class="flex flex-col gap-4 sm:flex-1">
            <p
              class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
            >
              {address.label}
            </p>
            <p class="font-display text-base/[1.3] text-primary-foreground">
              {address.line1}<br />{address.line2}
            </p>
          </div>
          <div class="flex flex-col gap-4 sm:flex-1">
            <p
              class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
            >
              {contact.label}
            </p>
            <p class="font-display text-base/[1.3] text-primary-foreground">
              {contact.email}<br />{contact.phone}
            </p>
          </div>
        </div>
      </div>

      {/* Opening hours */}
      <div class="flex flex-col gap-4">
        <p
          class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
        >
          {hours.label}
        </p>
        <ul class="flex flex-col gap-4">
          {
            hours.rows.map((row, i) => (
              <li
                class={cn(
                  "flex items-center justify-between pb-3 font-display text-base/[1.3]",
                  i < hours.rows.length - 1 &&
                    "border-b border-primary-foreground/20",
                  row.muted
                    ? "text-primary-foreground/60"
                    : "text-primary-foreground",
                )}
              >
                <span>{row.day}</span>
                <span>{row.time}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {/* CTA button */}
    <a href={cta.href} class={buttonVariants({ variant: "main-light" })}>
      {cta.label}
    </a>
  </div>
</section>
