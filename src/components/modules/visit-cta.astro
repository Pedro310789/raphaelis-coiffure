---
import { buttonVariants } from "@/components/primitives/button.astro";
import Heading from "@/components/primitives/heading.astro";
import { cn } from "@/lib/utils";

export interface Props {
  overline: string;
  heading: { line1: string; line2: string };
  body: string;
  address: { label: string; line1: string; line2: string };
  contact: { label: string; email: string; phone: string };
  hours: {
    label: string;
    rows: { day: string; time: string; muted?: boolean }[];
  };
  cta: { label: string; href: string };
}

const { overline, heading, body, address, contact, hours, cta } = Astro.props;
---

<section class="bg-primary px-5 py-12 sm:px-8 md:py-20 lg:px-45.5 lg:py-24">
  <div class="flex flex-col items-center gap-12">
    {/* Info section: heading block + address/hours block */}
    <div class="flex max-w-160 flex-col gap-8 lg:gap-16">
      {/* Overline + H3 + body — centered */}
      <div class="flex flex-col items-start md:items-center gap-8 text-center">
        <div class="flex flex-col items-center gap-4">
          <p
            class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
          >
            {overline}
          </p>
          <div class="h-px w-12 bg-muted-foreground" aria-hidden="true"></div>
        </div>
        <div
          class="flex flex-col items-start md:items-center text-left md:text-center gap-6"
        >
          <Heading
            as="h2"
            size="h3"
            balance={false}
            class="text-primary-foreground text-[36px]/none md:text-[38px]/none lg:text-[46px]/none"
          >
            <span class="inline-block">{heading.line1}</span>
            <span class="inline-block text-primary-foreground/70"
              >{heading.line2}</span
            >
          </Heading>
          <p
            class="text-sm/normal tracking-[0.01em] text-primary-foreground/60"
          >
            {body}
          </p>
        </div>
      </div>

      {/* Address + Contact (left) · Hours (right) */}
      <div class="flex flex-col gap-8 lg:flex-row">
        {
          /* Address + Contact: stack on mobile, row on sm, column again on lg */
        }
        <div class="flex gap-8 lg:w-60 lg:shrink-0 lg:flex-col">
          <div class="flex flex-1 flex-col gap-4 lg:flex-none">
            <p
              class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
            >
              {address.label}
            </p>
            <p class="font-display text-base/[1.3] text-primary-foreground">
              {address.line1}<br />{address.line2}
            </p>
          </div>
          <div class="flex flex-1 flex-col gap-4 lg:flex-none">
            <p
              class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
            >
              {contact.label}
            </p>
            <p class="font-display text-base/[1.3] text-primary-foreground">
              {contact.email}<br />{contact.phone}
            </p>
          </div>
        </div>

        {/* Hours */}
        <div class="flex flex-1 flex-col gap-4">
          <p
            class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
          >
            {hours.label}
          </p>
          <ul class="flex flex-col gap-6">
            {
              hours.rows.map((row, i) => (
                <li
                  class={cn(
                    "flex items-center justify-between pb-3 font-display text-base/[1.3]",
                    i < hours.rows.length - 1 &&
                      "border-b border-primary-foreground/20",
                    row.muted
                      ? "text-primary-foreground/60"
                      : "text-primary-foreground",
                  )}
                >
                  <span>{row.day}</span>
                  <span>{row.time}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    {/* CTA */}
    <a href={cta.href} class={buttonVariants({ variant: "main-light" })}>
      {cta.label}
    </a>
  </div>
</section>
