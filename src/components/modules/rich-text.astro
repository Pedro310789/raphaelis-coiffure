---
/**
 * RichText module.
 *
 * Wraps rendered MDX/Markdown content (via <slot />) or a pre-rendered HTML
 * string (via the `html` prop) with Tailwind Typography styling.
 */
import Container from '@/components/primitives/container.astro';
import { cn } from '@/lib/utils';

export interface Props {
  /** Pre-rendered HTML. Takes precedence over slot content. */
  html?: string;
  class?: string;
  /** Typography size preset — matches prose-sm/prose/prose-lg from @tailwindcss/typography. */
  size?: 'sm' | 'base' | 'lg';
}

const { html, size = 'base', class: className } = Astro.props;

const proseSize = {
  sm: 'prose-sm',
  base: 'prose',
  lg: 'prose-lg',
}[size];
---

<Container size="sm" as="article" class="py-12 md:py-16">
  {
    /*
     * `prose-headings:scroll-mt-24` gives sticky-header friendly anchor offsets.
     * Additional tweaks keep Tailwind typography aligned with our token system.
     */
  }
  <div
    class={cn(
      proseSize,
      'max-w-none',
      'prose-headings:scroll-mt-24 prose-headings:font-semibold prose-headings:tracking-tight',
      'prose-a:text-primary prose-a:no-underline hover:prose-a:underline',
      'prose-code:rounded prose-code:bg-muted prose-code:px-1 prose-code:py-0.5 prose-code:text-sm prose-code:before:content-none prose-code:after:content-none',
      'prose-pre:bg-muted prose-pre:text-foreground prose-pre:border',
      'prose-hr:border-border',
      className,
    )}
  >
    {html ? <Fragment set:html={html} /> : <slot />}
  </div>
</Container>
