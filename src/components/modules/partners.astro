---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Container from "@/components/primitives/container.astro";

const partnerImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/partners/*",
  { eager: true },
);

export interface Props {
  overline: string;
  logos: Array<{ src: string; alt: string }>;
}

const { overline, logos } = Astro.props;
---

<section class="bg-secondary">
  <Container
    size="page"
    as="div"
    class="flex flex-col items-center gap-8 py-10 md:py-18"
  >
    <div class="flex flex-col items-center gap-4">
      <p
        class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
      >
        {overline}
      </p>
      <div class="h-px w-12 bg-muted-foreground" aria-hidden="true"></div>
    </div>

    <ul
      class="flex list-none flex-wrap items-center justify-center gap-8 md:gap-x-16 lg:gap-x-46 lg:gap-y-8"
    >
      {
        logos.map((logo) => {
          const key = `/${logo.src}`;
          const imgData = partnerImages[key]?.default;
          return (
            <li class="flex h-16 w-16 shrink-0 items-center justify-center md:h-20 md:w-20 lg:h-24 lg:w-24">
              {imgData ? (
                <Image
                  src={imgData}
                  alt={logo.alt}
                  class="h-full w-full object-contain"
                  widths={[64, 80, 96]}
                  sizes="(min-width: 1024px) 96px, (min-width: 768px) 80px, 64px"
                  loading="lazy"
                />
              ) : (
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-full w-full object-contain"
                  loading="lazy"
                />
              )}
            </li>
          );
        })
      }
    </ul>
  </Container>
</section>
