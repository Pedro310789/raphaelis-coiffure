---
/**
 * FAQ module.
 *
 * Uses native <details>/<summary> for zero-JS accordion behavior.
 * Fully accessible (keyboard, screen reader) out of the box.
 *
 * Trade-off: no animation by default. If a client asks for smooth
 * expand/collapse, add a React/Vue island using shadcn's Accordion,
 * or use the CSS-only `interpolate-size: allow-keywords` approach
 * (Chrome 129+ — check browser support for your client's audience).
 */
import Container from '@/components/primitives/container.astro';
import Heading from '@/components/primitives/heading.astro';
import { cn } from '@/lib/utils';

export interface FAQItem {
  question: string;
  /** Plain text or pre-rendered HTML. */
  answer: string;
  /** Whether this item is open by default. */
  open?: boolean;
}

export interface Props {
  title?: string;
  description?: string;
  items: FAQItem[];
  class?: string;
}

const { title, description, items, class: className } = Astro.props;
---

<section class={cn('py-16 md:py-24', className)}>
  <Container size="sm">
    {
      (title || description) && (
        <div class="text-center mb-12 space-y-4">
          {title && (
            <Heading as="h2" size="2xl">
              {title}
            </Heading>
          )}
          {description && (
            <p class="text-lg text-muted-foreground text-balance">{description}</p>
          )}
        </div>
      )
    }

    <div class="divide-y divide-border border-y">
      {
        items.map((item) => (
          <details class="group py-4" open={item.open}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium text-foreground hover:text-foreground/80 transition-colors [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <svg
                class="size-5 shrink-0 transition-transform duration-200 group-open:rotate-45"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M12 5v14M5 12h14" stroke-linecap="round" />
              </svg>
            </summary>
            <div class="mt-3 text-muted-foreground" set:html={item.answer} />
          </details>
        ))
      }
    </div>
  </Container>
</section>
