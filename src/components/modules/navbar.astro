---
import Container from "@/components/primitives/container.astro";
import { Image } from "astro:assets";
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/translations";
import { alternateLocalePath, localizedPath } from "@/i18n/routes";
import menuBgImage from "@/assets/images/hero.png";
import logoRaphaelis from "@/assets/icons/logo-raphaelis.svg";

const locale = (Astro.currentLocale ?? "fr") as Lang;
const t = useTranslations(locale);

const navLinks = [
  { label: t("nav.home"), href: localizedPath("home", locale) },
  { label: t("nav.maison"), href: localizedPath("maison", locale) },
  { label: t("nav.services"), href: localizedPath("services", locale) },
  { label: t("nav.collection"), href: localizedPath("collection", locale) },
  { label: t("nav.contact"), href: localizedPath("contact", locale) },
];

const frHref = alternateLocalePath(Astro.url.pathname, locale, "fr");
const enHref = alternateLocalePath(Astro.url.pathname, locale, "en");
---

{/* Mobile menu overlay */}
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label={t("nav.label")}
  class="fixed inset-0 z-50 hidden flex-col overflow-hidden md:hidden"
>
  {/* Background: full-bleed photo + gradient vignette */}
  <div aria-hidden class="pointer-events-none absolute inset-0">
    <Image
      src={menuBgImage}
      alt=""
      class="absolute inset-0 size-full object-cover object-[75%_50%]"
    />
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 40%), linear-gradient(0deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 40%), linear-gradient(90deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.2) 100%)"
    >
    </div>
  </div>

  {/* Top bar: logo (left) + close (right) */}
  <div
    class="absolute inset-x-5 top-0 z-10 flex items-center justify-between py-4"
  >
    <a href={localizedPath("home", locale)} aria-label="Raphaeli's — Accueil">
      <Image
        src={logoRaphaelis}
        alt="Raphaeli's"
        width={72}
        height={55}
        class="h-[55px] w-[72px] object-contain"
      />
    </a>
    <button
      id="menu-close"
      aria-label={t("nav.closeMenu")}
      class="flex items-center justify-center text-white"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
      >
        <line x1="4" y1="4" x2="20" y2="20"></line>
        <line x1="20" y1="4" x2="4" y2="20"></line>
      </svg>
    </button>
  </div>

  {/* Content: nav links + language selector pushed to bottom */}
  <div class="relative flex flex-1 flex-col justify-between px-5 pt-40 pb-4">
    <nav aria-label={t("nav.label")} class="flex flex-col gap-10">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="w-full border-b border-[rgba(217,217,217,0.5)] pb-4 pt-[6.5px] text-xs/[1.3] font-normal uppercase tracking-wider text-white transition-colors hover:text-white/70"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    {/* Language selector — bottom center */}
    <div
      class="flex items-center justify-center gap-3"
      aria-label={t("lang.selector")}
    >
      {
        locale === "fr" ? (
          <span
            lang="fr"
            aria-current="true"
            class="cursor-default text-xs/[1.3] font-normal uppercase tracking-wider text-white"
          >
            FR
          </span>
        ) : (
          <a
            href={frHref}
            lang="fr"
            class="text-xs/[1.3] font-normal uppercase tracking-wider text-primary-foreground/60 transition-colors hover:text-white"
          >
            FR
          </a>
        )
      }
      <div class="h-3 w-px bg-primary-foreground/40" aria-hidden="true"></div>
      {
        locale === "en" ? (
          <span
            lang="en"
            aria-current="true"
            class="cursor-default text-xs/[1.3] font-normal uppercase tracking-wider text-white"
          >
            EN
          </span>
        ) : (
          <a
            href={enHref}
            lang="en"
            class="text-xs/[1.3] font-normal uppercase tracking-wider text-primary-foreground/60 transition-colors hover:text-white"
          >
            EN
          </a>
        )
      }
    </div>
  </div>
</div>

{/* Navbar */}
<header class="relative z-10 h-22 md:h-24">
  <Container size="page" class="flex h-full items-center justify-between">
    {/* Left: Logo */}
    <a href={localizedPath("home", locale)} aria-label="Raphaeli's — Accueil">
      <Image
        src={logoRaphaelis}
        alt="Raphaeli's"
        width={88}
        height={67}
        class="h-[55px] w-[72px] object-contain md:h-[67px] md:w-[88px]"
      />
    </a>

    {/* Center: Nav links (desktop only) */}
    <nav aria-label={t("nav.label")} class="hidden md:block">
      <ul class="flex items-center gap-10">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-xs/[1.3] font-normal uppercase tracking-wider text-white transition-colors hover:text-primary-foreground/60"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {/* Right: language selector (desktop) + hamburger (mobile) */}
    <div class="flex items-center gap-5">
      <div
        class="hidden items-center gap-3 md:flex"
        aria-label={t("lang.selector")}
      >
        {
          locale === "fr" ? (
            <span
              lang="fr"
              aria-current="true"
              class="cursor-default text-xs/[1.3] font-normal uppercase tracking-wider text-white"
            >
              FR
            </span>
          ) : (
            <a
              href={frHref}
              lang="fr"
              class="text-xs/[1.3] font-normal uppercase tracking-wider text-primary-foreground/60 transition-colors hover:text-white"
            >
              FR
            </a>
          )
        }
        <div class="h-3 w-px bg-primary-foreground/40" aria-hidden="true"></div>
        {
          locale === "en" ? (
            <span
              lang="en"
              aria-current="true"
              class="cursor-default text-xs/[1.3] font-normal uppercase tracking-wider text-white"
            >
              EN
            </span>
          ) : (
            <a
              href={enHref}
              lang="en"
              class="text-xs/[1.3] font-normal uppercase tracking-wider text-primary-foreground/60 transition-colors hover:text-white"
            >
              EN
            </a>
          )
        }
      </div>

      <button
        id="menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t("nav.openMenu")}
        class="flex flex-col items-center justify-center gap-2 text-white md:hidden"
      >
        <span class="block h-px w-6 bg-white"></span>
        <span class="block h-px w-6 bg-white"></span>
        <span class="block h-px w-6 bg-white"></span>
      </button>
    </div>
  </Container>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const closeBtn = document.getElementById("menu-close");
  const menu = document.getElementById("mobile-menu");

  function openMenu() {
    menu?.classList.remove("hidden");
    menu?.classList.add("flex");
    toggle?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    menu?.classList.remove("flex");
    menu?.classList.add("hidden");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });
</script>
