---
/**
 * Commitments — "Quelques engagements mutuels" mutual-commitments notice (Figma 3444:8163).
 *
 * Centered overline + divider + H2 above a single width-capped body paragraph. Purely
 * typographic — no images, no CTAs. Sits on Primary/100 (#F7F6F3 → bg-secondary) with
 * generous vertical rhythm. Mobile-first: the H2 scales 36 → 46 → 56px across breakpoints
 * (Figma has no mobile scale, so smaller steps are inferred), section gap/padding tighten
 * on small screens, and the body measure caps at 856px on desktop while staying fluid below.
 */
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";

export interface Props {
  overline: string;
  heading: string;
  body: string[];
}

const { overline, heading, body: bodyProp } = Astro.props;
const body = Array.isArray(bodyProp) ? bodyProp : [bodyProp];
---

<section class="bg-secondary">
  <Container size="page" class="py-16 md:py-20 xl:py-23">
    <div class="flex flex-col items-center gap-10 md:gap-14">
      {/* Heading block: overline + divider + H2 */}
      <div class="flex flex-col items-center gap-6 text-center">
        <div class="flex flex-col items-center gap-4">
          <p
            class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
          >
            {overline}
          </p>
          <div class="h-px w-12 bg-muted-foreground" aria-hidden="true"></div>
        </div>
        <Heading
          as="h2"
          size="h2"
          balance={false}
          animation="fade-up"
          class="text-[36px]/none md:text-[46px]/none xl:text-[56px]/none"
        >
          {heading}
        </Heading>
      </div>

      {/* Body: centered, capped at the Figma 856px measure */}
      <div
        class="reveal-on-scroll animate-fade-up flex flex-col gap-4"
        style="--reveal-delay: 120ms"
      >
        {
          body.map((paragraph) => (
            <p class="w-full max-w-214 text-center text-base/normal text-body-foreground">
              {paragraph}
            </p>
          ))
        }
      </div>
    </div>
  </Container>
</section>
