---
/**
 * MaisonStrengths — "Ce qui nous définit" credentials grid for the maison page (Figma 3430:3047).
 *
 * Centered overline + divider + H2, then a grid of numbered strengths. Each item is a roman
 * numeral + extending hairline rule above an H4 title and short body. No images, no CTAs —
 * purely typographic. Mobile-first: 1 column, 2 at sm, 3 at lg. Sits on the page background
 * (BG/100 #EDECE8) with 72px side padding inherited from Container size="page".
 */
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";

interface StrengthItem {
  numeral: string;
  title: string;
  body: string;
}

export interface Props {
  overline: string;
  heading: string;
  items: StrengthItem[];
}

const { overline, heading, items } = Astro.props;
---

<section class="bg-background">
  <Container size="page" as="div" class="py-10 md:py-20 xl:py-24">
    <div class="flex flex-col items-center gap-14 md:gap-16 xl:gap-20">
      {/* Heading block */}
      <div class="flex flex-col items-center gap-6 text-center">
        <div class="flex flex-col items-center gap-4">
          <p
            class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
          >
            {overline}
          </p>
          <div class="h-px w-12 bg-muted-foreground" aria-hidden="true"></div>
        </div>
        <Heading
          as="h2"
          size="h2"
          balance={false}
          class="text-center text-[36px]/none md:text-[46px]/none xl:text-[56px]/none"
        >
          {heading}
        </Heading>
      </div>

      {/* Strengths grid: 1 col mobile, 2 at sm, 3 at lg */}
      <div class="grid w-full grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {
          items.map((item) => (
            <div class="flex flex-col gap-4 md:gap-6">
              {/* Numeral + extending divider */}
              <div class="flex items-center gap-6">
                <span
                  class="w-5 shrink-0 font-display text-xl/[1.3] italic text-muted-foreground"
                  aria-hidden="true"
                >
                  {item.numeral}
                </span>
                <div
                  class="h-px flex-1 bg-muted-foreground"
                  aria-hidden="true"
                />
              </div>

              {/* Title + body */}
              <div class="flex flex-col gap-4">
                <Heading
                  as="h3"
                  size="h4"
                  class="text-[26px]/[1.2] md:text-[28px]/[1.2]"
                >
                  {item.title}
                </Heading>
                <p class="text-sm/normal tracking-[0.01em] text-body-foreground">
                  {item.body}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
