---
import type { CTALink } from "@/types/modules";
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import foundersImage from "@/assets/images/founders.png";
import rightIcon from "@/assets/icons/right-icon.svg?raw";

export interface Props {
  overline: string;
  heading: string[];
  body: string[];
  imageCaption: string;
  cta: CTALink;
}

const { overline, heading, body, imageCaption, cta } = Astro.props;
---

<section class="bg-muted">
  <Container size="page" as="div" class="py-10 md:py-20 xl:py-24">
    <div
      class="flex flex-col gap-10 md:flex-row md:items-center md:gap-10 xl:gap-33.5"
    >
      {/* Left: portrait + caption */}
      <div class="flex flex-col gap-3 md:shrink-0">
        <div
          class="relative w-full overflow-hidden rounded-none aspect-526/745 xl:w-131.5"
        >
          <Image
            src={foundersImage}
            alt=""
            widths={[526, 800, 1080]}
            sizes="(min-width: 1024px) 526px, (min-width: 768px) 40vw, 100vw"
            class="absolute inset-0 size-full object-cover object-top"
            loading="lazy"
          />
        </div>
        <p
          class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
        >
          {imageCaption}
        </p>
      </div>

      {/* Right: text content */}
      <div class="flex flex-col gap-10 md:gap-10 xl:gap-14">
        {/* Heading block + body */}
        <div class="flex flex-col gap-6 md:gap-8">
          {/* Overline + divider + H2 */}
          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-4">
              <p
                class="text-[10px]/[1.3] md:text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
              >
                {overline}
              </p>
              <div class="h-px w-12 bg-muted-foreground" aria-hidden="true">
              </div>
            </div>
            <Heading
              as="h2"
              size="h2"
              balance={false}
              class="text-[36px]/none md:text-[46px]/none xl:text-[56px]/none"
            >
              {heading.map((line) => <span class="block">{line}</span>)}
            </Heading>
          </div>

          {/* Body paragraphs */}
          <div class="flex flex-col gap-6">
            {
              body.map((paragraph) => (
                <p class="text-sm/normal md:text-base/normal text-body-foreground">
                  {paragraph}
                </p>
              ))
            }
          </div>
        </div>

        {/* CTA */}
        <a
          href={cta.href}
          class={buttonVariants({
            variant: "tertiary",
            size: "noGutter",
          })}
          class:list={"justify-start"}
        >
          {cta.label}
          <Fragment set:html={rightIcon} />
        </a>
      </div>
    </div>
  </Container>
</section>
