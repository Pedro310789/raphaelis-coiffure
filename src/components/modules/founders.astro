---
import type { CTALink } from "@/types/modules";
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import foundersImage from "@/assets/founders.png";

export interface Props {
  overline: string;
  heading: string[];
  body: string[];
  imageCaption: string;
  cta: CTALink;
}

const { overline, heading, body, imageCaption, cta } = Astro.props;
---

<section class="bg-muted">
  <Container size="page" as="div" class="py-16 md:py-20 lg:py-24">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-33.5">
      {/* Left: portrait + caption */}
      <div class="flex flex-col gap-3 lg:shrink-0">
        <div
          class="relative w-full overflow-hidden rounded-none aspect-526/745 lg:w-131.5"
        >
          <Image
            src={foundersImage}
            alt=""
            widths={[526, 800, 1080]}
            sizes="(min-width: 1024px) 526px, 100vw"
            class="absolute inset-0 size-full object-cover object-top"
            loading="lazy"
          />
        </div>
        <p
          class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
        >
          {imageCaption}
        </p>
      </div>

      {/* Right: text content */}
      <div class="flex flex-col gap-10 lg:gap-14">
        {/* Heading block + body */}
        <div class="flex flex-col gap-6 lg:gap-8">
          {/* Overline + divider + H2 */}
          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-4">
              <p
                class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
              >
                {overline}
              </p>
              <div class="h-px w-12 bg-muted-foreground" aria-hidden="true">
              </div>
            </div>
            <Heading
              as="h2"
              size="h2"
              balance={false}
              class="text-[36px]/none md:text-[46px]/none lg:text-[56px]/none"
            >
              {heading.map((line) => <span class="block">{line}</span>)}
            </Heading>
          </div>

          {/* Body paragraphs */}
          <div class="flex flex-col gap-6">
            {
              body.map((paragraph) => (
                <p class="text-base/normal text-body-foreground">{paragraph}</p>
              ))
            }
          </div>
        </div>

        {/* CTA */}
        <a href={cta.href} class={buttonVariants({ variant: "tertiary" })}>
          {cta.label}
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</section>
