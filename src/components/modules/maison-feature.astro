---
/**
 * MaisonFeature — two-column image + text block for the maison page (Figma 3430:3012 / 3430:3029).
 *
 * One configurable composition behind the "À propos" and "Les fondatrices" sections: photo on one
 * side, overline + divider + H3 + body on the other. Props drive the image, its crop, an optional
 * tertiary CTA, body width, and section padding. Mobile-first: columns stack and the photo goes
 * full-width below the md breakpoint.
 */
import type { ImageMetadata } from "astro";
import type { CTALink } from "@/types/modules";
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/primitives/button.astro";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import { cn } from "@/lib/utils";
import rightIcon from "@/assets/icons/right-icon.svg?raw";

export interface Props {
  overline: string;
  heading: string;
  body: string[];
  image: ImageMetadata;
  imageAlt: string;
  imagePosition?: "center" | "top";
  cta?: CTALink;
  class?: string;
}

const {
  overline,
  heading,
  body,
  image,
  imageAlt,
  imagePosition = "center",
  cta,
  class: className,
} = Astro.props;
---

<section class="bg-muted">
  <Container
    size="page"
    as="div"
    class={cn("py-16 md:py-20 xl:py-24", className)}
  >
    <div
      class="flex flex-col gap-10 md:flex-row md:items-center md:gap-16 xl:gap-33.5"
    >
      {/* Left: photo */}
      <div
        class="relative w-full shrink-0 overflow-hidden aspect-526/560 md:w-2/5 xl:w-131.5"
      >
        <Image
          src={image}
          alt={imageAlt}
          widths={[526, 800, 1052]}
          sizes="(min-width: 1280px) 526px, (min-width: 768px) 40vw, 100vw"
          class:list={[
            "absolute inset-0 size-full object-cover",
            imagePosition === "top" && "object-top",
          ]}
          loading="lazy"
        />
      </div>

      {/* Right: text content */}
      <div
        class:list={[
          "flex flex-1 flex-col",
          cta ? "gap-10 xl:gap-14" : "gap-6 md:gap-8",
        ]}
      >
        {/* Heading block + body */}
        <div class="flex flex-col gap-6 md:gap-8">
          {/* Overline + divider + H3 */}
          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-4">
              <p
                class="text-xs/[1.3] font-normal uppercase tracking-wider text-muted-foreground"
              >
                {overline}
              </p>
              <div class="h-px w-12 bg-muted-foreground" aria-hidden="true">
              </div>
            </div>
            <Heading
              as="h2"
              size="h3"
              balance={false}
              class="text-[32px]/none md:text-[40px]/none xl:text-[46px]/none"
            >
              {heading}
            </Heading>
          </div>

          {/* Body paragraphs */}
          <div class="flex flex-col gap-6">
            {
              body.map((paragraph) => (
                <p class="text-base/normal text-body-foreground max-w-138">
                  {paragraph}
                </p>
              ))
            }
          </div>
        </div>

        {/* CTA */}
        {
          cta && (
            <a
              href={cta.href}
              class={cn(
                buttonVariants({ variant: "tertiary" }),
                "self-start px-0",
              )}
            >
              {cta.label}
              <Fragment set:html={rightIcon} />
            </a>
          )
        }
      </div>
    </div>
  </Container>
</section>
