---
/**
 * PageHero — full-screen hero shared by the Maison (Figma 3430:2427) and
 * Services (Figma 3435:3408) pages.
 *
 * Same three-band structure as the home Hero (navbar → centered title block →
 * discover/slogan band), but the title is H2-sized and the centered block shows
 * an intro paragraph instead of an overline + CTA button. The background image
 * (and its optional object-position) is passed in per page; everything else is
 * shared. Reuses the navbar and the discover band markup with the home Hero.
 */
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Container from "@/components/primitives/container.astro";
import Heading from "@/components/primitives/heading.astro";
import Navbar from "@/components/modules/navbar.astro";

export interface Props {
  heading: string;
  body: string;
  discover: { label: string; slogan: string; address: string };
  /** Full-bleed background image (imported asset). */
  image: ImageMetadata;
  /** Optional extra classes for the background image, e.g. `object-[50%_30%]`. */
  imageClass?: string;
}

const { heading, body, discover, image, imageClass } = Astro.props;
---

<section class="relative flex min-h-150 flex-col overflow-hidden">
  {/* Background: full-bleed photo + gradient vignette */}
  <div aria-hidden class="pointer-events-none absolute inset-0">
    <Image
      src={image}
      alt=""
      loading="eager"
      fetchpriority="high"
      class:list={["absolute inset-0 size-full object-cover", imageClass]}
    />
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.3) 100%), linear-gradient(0deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.3) 100%), linear-gradient(90deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.2) 100%)"
    >
    </div>
  </div>

  <Navbar />

  {/* Hero content — vertically centered in remaining space */}
  <div
    class="relative z-10 flex flex-1 flex-col items-center justify-center px-4 py-10 md:py-0"
  >
    <div class="flex w-full max-w-117 flex-col items-center gap-8">
      {/* Title group: H2 + divider */}
      <div class="flex w-full flex-col items-center gap-6 md:gap-8">
        <Heading
          as="h1"
          size="h2"
          balance={false}
          animation="fade-up"
          class="w-full text-center text-[40px]/none text-white md:text-[56px]/none"
        >
          {heading}
        </Heading>
        <hr class="w-32 border-background" />
      </div>

      {/* Intro paragraph */}
      <p
        class="text-center text-base/normal font-normal text-primary-foreground/60"
      >
        {body}
      </p>
    </div>
  </div>

  {/* Discover section — bottom of viewport */}
  <div class="relative z-10 pb-6">
    {/* Discover label + vertical line, centered */}
    <div class="flex flex-col items-center gap-3 pb-4 md:pb-2">
      <span
        class="text-xs/[1.3] font-normal uppercase tracking-wider text-primary-foreground/60"
      >
        {discover.label}
      </span>
      <div class="h-10 w-px bg-primary-foreground/60" aria-hidden="true"></div>
    </div>

    {/* Slogan (left) + address (right); stacks on mobile */}
    <Container
      size="page"
      class="flex flex-col items-center gap-2 md:flex-row md:justify-between md:gap-0"
    >
      <span
        class="text-xs/[1.3] font-normal uppercase tracking-wider text-primary-foreground/60"
      >
        {discover.slogan}
      </span>
      <span
        class="text-xs/[1.3] font-normal uppercase tracking-wider text-primary-foreground/60"
      >
        {discover.address}
      </span>
    </Container>
  </div>
</section>
