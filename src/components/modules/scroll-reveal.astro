---
/**
 * ScrollReveal — markup-free behavior component. Observes every
 * `.reveal-on-scroll` element on the page and adds `.is-visible` when it enters
 * the viewport, triggering the CSS reveal transitions (see global.css). Include
 * once per page (it lives in base-layout). Above-the-fold elements reveal on
 * load since the observer fires immediately.
 */
---

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
  );

  const arm = () => {
    for (const el of document.querySelectorAll(".reveal-on-scroll")) {
      observer.observe(el);
    }
  };

  arm();

  // On a back/forward-cache (bfcache) restore the page returns with `.is-visible`
  // already applied and this module is not re-executed, so the animation never
  // replays. Reset the elements to their hidden state and re-observe them.
  window.addEventListener("pageshow", (event) => {
    if (!event.persisted) return;
    for (const el of document.querySelectorAll(".reveal-on-scroll")) {
      el.classList.remove("is-visible");
    }
    // Paint the hidden state before re-observing so the transition replays.
    requestAnimationFrame(() => requestAnimationFrame(arm));
  });
</script>
