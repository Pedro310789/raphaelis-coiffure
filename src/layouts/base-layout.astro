---
import "@/styles/global.css";
import { Font, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import ScrollReveal from "@/components/modules/scroll-reveal.astro";

export interface Props {
  title: string;
  description?: string;
  /** Repo-relative path to the social share image, e.g. `src/assets/images/og/home.jpg`. */
  image?: string;
  imageAlt?: string;
}

const { title, description, image, imageAlt } = Astro.props;
const lang = Astro.currentLocale ?? "fr";

// Open Graph locale codes (Belgium-based salon, FR default / EN secondary).
const ogLocale = lang === "en" ? "en_GB" : "fr_BE";

// Resolve the featured image the same way the modules do (string path →
// optimized asset via import.meta.glob), falling back to a site-wide default.
const ogImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/**/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const defaultOg = ogImages["/src/assets/images/og/og-default.jpg"]?.default;
const selectedOg = image ? ogImages[`/${image}`]?.default : undefined;
const ogSource = selectedOg ?? defaultOg;

// Absolute URLs are required for OG/Twitter image and og:url/canonical.
const canonical = new URL(Astro.url.pathname, Astro.site);
let ogImageUrl: string | undefined;
if (ogSource) {
  const optimized = await getImage({
    src: ogSource,
    width: 1200,
    format: "jpg",
  });
  ogImageUrl = new URL(optimized.src, Astro.site).href;
}
const ogImageAlt = imageAlt ?? title;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical.href} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Maison Raphaelis" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical.href} />
    <meta property="og:locale" content={ogLocale} />
    {
      ogImageUrl && (
        <>
          <meta property="og:image" content={ogImageUrl} />
          <meta property="og:image:alt" content={ogImageAlt} />
        </>
      )
    }

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-sans" preload />
  </head>
  <body class="font-sans">
    <slot />
    <ScrollReveal />
  </body>
</html>
