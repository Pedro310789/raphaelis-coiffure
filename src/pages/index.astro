---
import BaseLayout from "@/layouts/base-layout.astro";
import {
  Hero,
  Founders,
  Services,
  Testimonials,
  Collection,
  Partners,
} from "@/components/modules";
import { getSection } from "@/lib/content";
import type { Lang } from "@/i18n/translations";

const locale = (Astro.currentLocale ?? "fr") as Lang;
const hero = await getSection("hero", locale, "home");
const founders = await getSection("founders", locale, "home");
const services = await getSection("services", locale, "home");
const testimonials = await getSection("testimonials", locale, "home");
const collection = await getSection("collection", locale, "home");
const partners = await getSection("partners", locale, "home");
const { seo, heading, subtitle, cta, discover } = hero.data;
---

<BaseLayout title={seo.title} description={seo.description}>
  <Hero {heading} {subtitle} {cta} {discover} />
  <Founders
    overline={founders.data.overline}
    heading={founders.data.heading}
    body={founders.data.body}
    imageCaption={founders.data.imageCaption}
    cta={founders.data.cta}
  />
  <Services
    overline={services.data.overline}
    heading={services.data.heading}
    cards={services.data.cards}
  />
  <Collection
    overline={collection.data.overline}
    heading={collection.data.heading}
    images={collection.data.images}
    cta={collection.data.cta}
  />
  <Testimonials
    overline={testimonials.data.overline}
    heading={testimonials.data.heading}
    cards={testimonials.data.cards}
  />
  <Partners
    overline={partners.data.overline}
    logos={partners.data.logos}
  />
</BaseLayout>
