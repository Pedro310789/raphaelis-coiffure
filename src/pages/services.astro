---
import BaseLayout from "@/layouts/base-layout.astro";
import {
  PageHero,
  ServicesDisciplines,
  ServicesVip,
  VisitCta,
  Footer,
} from "@/components/modules";
import { getSection } from "@/lib/content";
import type { Lang } from "@/i18n/translations";
import heroImage from "@/assets/images/hero_services.jpg";

const locale = (Astro.currentLocale ?? "fr") as Lang;
const seo = await getSection("seo", locale, "services");
const hero = await getSection("services-hero", locale, "services");
const servicesDisciplines = await getSection(
  "services-disciplines",
  locale,
  "services",
);
const servicesVip = await getSection("services-vip", locale, "services");
const visitCta = await getSection("visit-cta", locale, "home");
const footer = await getSection("footer", locale, "home");
const { heading, body, discover } = hero.data;
---

<BaseLayout
  title={seo.data.title}
  description={seo.data.description}
  image={seo.data.image}
  imageAlt={seo.data.imageAlt}
>
  <PageHero {heading} {body} {discover} image={heroImage} />
  <ServicesDisciplines {...servicesDisciplines.data} />
  <ServicesVip {...servicesVip.data} />
  <VisitCta
    overline={visitCta.data.overline}
    heading={visitCta.data.heading}
    body={visitCta.data.body}
    address={visitCta.data.address}
    contact={visitCta.data.contact}
    hours={visitCta.data.hours}
    cta={visitCta.data.cta}
  />
  <Footer
    brandName={footer.data.brandName}
    tagline={footer.data.tagline}
    nav={footer.data.nav}
    contact={footer.data.contact}
    social={footer.data.social}
    legal={footer.data.legal}
  />
</BaseLayout>
