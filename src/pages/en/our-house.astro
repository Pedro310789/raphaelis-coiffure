---
import BaseLayout from "@/layouts/base-layout.astro";
import {
  PageHero,
  MaisonFeature,
  MaisonVision,
  VisitCta,
  Footer,
} from "@/components/modules";
import { getSection } from "@/lib/content";
import type { Lang } from "@/i18n/translations";
import heroImage from "@/assets/images/hero_about.jpg";
import aboutImage from "@/assets/images/founders.jpg";
import foundersImage from "@/assets/images/founders_about.jpg";
import monogram from "@/assets/images/monogram.png";
import visionLeftImage from "@/assets/images/atmosphere_about.jpg";
import visionRightImage from "@/assets/images/atmosphere_1_about.jpg";

const locale = (Astro.currentLocale ?? "en") as Lang;
const seo = await getSection("seo", locale, "maison");
const hero = await getSection("maison-hero", locale, "maison");
const about = await getSection("maison-about", locale, "maison");
const vision = await getSection("maison-vision", locale, "maison");
const founders = await getSection("maison-founders", locale, "maison");
const visitCta = await getSection("visit-cta", locale, "home");
const footer = await getSection("footer", locale, "home");
const { heading, body, discover } = hero.data;
---

<BaseLayout
  title={seo.data.title}
  description={seo.data.description}
  image={seo.data.image}
  imageAlt={seo.data.imageAlt}
>
  <PageHero
    {heading}
    {body}
    {discover}
    image={heroImage}
    imageClass="object-[50%_30%]"
  />
  <MaisonFeature
    overline={about.data.overline}
    heading={about.data.heading}
    body={about.data.body}
    image={foundersImage}
    imageAlt={about.data.imageAlt}
    cta={about.data.cta}
  />
  <MaisonFeature
    overline={founders.data.overline}
    heading={founders.data.heading}
    body={founders.data.body}
    image={aboutImage}
    imageAlt={founders.data.imageAlt}
    class="pt-8 md:pt-10 xl:pt-12"
  />
  <MaisonVision
    overline={vision.data.overline}
    heading={vision.data.heading}
    body={vision.data.body}
    monogram={monogram}
    leftImage={visionLeftImage}
    leftImageAlt={vision.data.leftImageAlt}
    rightImage={visionRightImage}
    rightImageAlt={vision.data.rightImageAlt}
  />
  <VisitCta
    overline={visitCta.data.overline}
    heading={visitCta.data.heading}
    body={visitCta.data.body}
    address={visitCta.data.address}
    contact={visitCta.data.contact}
    hours={visitCta.data.hours}
    cta={visitCta.data.cta}
  />
  <Footer
    brandName={footer.data.brandName}
    tagline={footer.data.tagline}
    nav={footer.data.nav}
    contact={footer.data.contact}
    social={footer.data.social}
    legal={footer.data.legal}
  />
</BaseLayout>
