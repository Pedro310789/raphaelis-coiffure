---
import BaseLayout from "@/layouts/base-layout.astro";
import {
  PageHero,
  ContactForm,
  Commitments,
  VisitCta,
  Footer,
} from "@/components/modules";
import { getSection } from "@/lib/content";
import type { Lang } from "@/i18n/translations";
import heroImage from "@/assets/images/hero_contact.jpg";

const locale = (Astro.currentLocale ?? "en") as Lang;
const seo = await getSection("seo", locale, "contact");
const hero = await getSection("contact-hero", locale, "contact");
const form = await getSection("contact-form", locale, "contact");
const commitments = await getSection("commitments", locale, "contact");
const visitCta = await getSection("visit-cta", locale, "home");
const footer = await getSection("footer", locale, "home");
const { heading, body, discover } = hero.data;
---

<BaseLayout
  title={seo.data.title}
  description={seo.data.description}
  image={seo.data.image}
  imageAlt={seo.data.imageAlt}
>
  <PageHero
    {heading}
    {body}
    {discover}
    image={heroImage}
    heroContentClass="max-w-157"
    heroParagraphClass="max-w-117"
  />
  <ContactForm {...form.data} />
  <VisitCta
    overline={visitCta.data.overline}
    heading={visitCta.data.heading}
    body={visitCta.data.body}
    address={visitCta.data.address}
    contact={visitCta.data.contact}
    hours={visitCta.data.hours}
    cta={visitCta.data.cta}
  />
  <Commitments {...commitments.data} />
  <Footer
    brandName={footer.data.brandName}
    tagline={footer.data.tagline}
    nav={footer.data.nav}
    contact={footer.data.contact}
    social={footer.data.social}
    legal={footer.data.legal}
  />
</BaseLayout>
