---
import BaseLayout from "@/layouts/base-layout.astro";
import {
  Hero,
  Founders,
  Services,
  Collection,
  Partners,
  VisitCta,
  Footer,
} from "@/components/modules";
import { getSection } from "@/lib/content";
import type { Lang } from "@/i18n/translations";

const locale = (Astro.currentLocale ?? "fr") as Lang;
const seo = await getSection("seo", locale, "home");
const hero = await getSection("hero", locale, "home");
const founders = await getSection("founders", locale, "home");
const services = await getSection("services", locale, "home");
const collection = await getSection("collection", locale, "home");
const partners = await getSection("partners", locale, "home");
const visitCta = await getSection("visit-cta", locale, "home");
const footer = await getSection("footer", locale, "home");
const { heading, subtitle, cta, discover } = hero.data;
---

<BaseLayout
  title={seo.data.title}
  description={seo.data.description}
  image={seo.data.image}
  imageAlt={seo.data.imageAlt}
>
  <Hero {heading} {subtitle} {cta} {discover} />
  <Founders
    overline={founders.data.overline}
    heading={founders.data.heading}
    body={founders.data.body}
    imageCaption={founders.data.imageCaption}
    cta={founders.data.cta}
  />
  <Services
    overline={services.data.overline}
    heading={services.data.heading}
    cards={services.data.cards}
  />
  <Collection
    overline={collection.data.overline}
    heading={collection.data.heading}
    images={collection.data.images}
    cta={collection.data.cta}
  />
  <Partners overline={partners.data.overline} logos={partners.data.logos} />
  <VisitCta
    overline={visitCta.data.overline}
    heading={visitCta.data.heading}
    body={visitCta.data.body}
    address={visitCta.data.address}
    contact={visitCta.data.contact}
    hours={visitCta.data.hours}
    cta={visitCta.data.cta}
  />
  <Footer
    brandName={footer.data.brandName}
    tagline={footer.data.tagline}
    nav={footer.data.nav}
    contact={footer.data.contact}
    social={footer.data.social}
    legal={footer.data.legal}
  />
</BaseLayout>
